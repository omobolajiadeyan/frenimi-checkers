NODE_ENV=development
PORT=4000
HOST=127.0.0.1
DB_FILE=data/checkers.sqlite
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000
# Render supplies RENDER_EXTERNAL_URL automatically. Add custom domains to
# CORS_ORIGINS as a comma-separated list.
TRUST_PROXY=false
HTTP_RATE_LIMIT_WINDOW_MS=60000
HTTP_RATE_LIMIT_MAX=300
